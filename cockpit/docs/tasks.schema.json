{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://remote-pi.dev/cockpit/tasks.schema.json",
  "title": "Cockpit Task Run config",
  "description": "Schema do .cockpit/tasks.json — ver cockpit/docs/tasks-json.md",
  "type": "object",
  "required": ["tasks"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "cwd": {
      "type": "string",
      "description": "Default de cwd pra todas as tasks (relativo à pasta do arquivo). Cada task pode sobrescrever."
    },
    "tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/task" }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "required": ["label", "command"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "description": "Nome curto exibido na lista." },
        "command": { "type": "string", "description": "Executável base (npm, flutter, go...)." },
        "args": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Args base, antes do profile."
        },
        "cwd": {
          "type": "string",
          "description": "Pasta de execução relativa à pasta do tasks.json (ou absoluta). Omitido = default top-level / raiz."
        },
        "kind": {
          "enum": ["watch", "oneShot"],
          "default": "oneShot",
          "description": "watch = processo vivo (dev-server); oneShot = roda e termina."
        },
        "interactiveKeys": {
          "type": "array",
          "items": { "$ref": "#/$defs/interactiveKey" }
        },
        "watch": { "$ref": "#/$defs/watch" },
        "progressPatterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/progressPattern" }
        },
        "profiles": {
          "type": "array",
          "items": { "$ref": "#/$defs/profile" }
        }
      }
    },
    "interactiveKey": {
      "type": "object",
      "required": ["key", "label"],
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string", "description": "Sequência escrita no PTY (ex.: r, R, q)." },
        "label": { "type": "string" },
        "icon": { "enum": ["refresh", "restart", "stop"] },
        "primary": { "type": "boolean", "default": false }
      }
    },
    "watch": {
      "type": "object",
      "required": ["onChange"],
      "additionalProperties": false,
      "properties": {
        "paths": { "type": "array", "items": { "type": "string" } },
        "ignore": { "type": "array", "items": { "type": "string" } },
        "onChange": {
          "type": "string",
          "description": "label de um interactiveKey, ou '__restart__'."
        },
        "debounceMs": { "type": "integer", "minimum": 0, "default": 300 }
      }
    },
    "progressPattern": {
      "type": "object",
      "required": ["begin", "end"],
      "additionalProperties": false,
      "properties": {
        "begin": { "type": "string", "description": "Regex de início de recompilação." },
        "end": { "type": "string", "description": "Regex de volta ao idle." }
      }
    },
    "profile": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "args": { "type": "array", "items": { "type": "string" } },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
